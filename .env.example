# PostgreSQL
POSTGRES_USER=raguser
POSTGRES_PASSWORD=ragpass
POSTGRES_DB=ragdb

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET=documents

# LLM - Cascata Groq → Gemini
GROQ_API_KEY=
GOOGLE_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
GEMINI_MODEL=gemini-1.5-flash

# Auth (Google OAuth)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
SESSION_SECRET=change-me-in-production-use-long-random-string
APP_URL=http://localhost:8000
DOMAIN_ALLOWED=cd2.com.br
ADMIN_EMAILS=
PUBLICADOR_EMAILS=

# Teste: ALLOW_ANONYMOUS_CHAT=true permite usar /rag e /chat sem login (apenas para desenvolvimento)
ALLOW_ANONYMOUS_CHAT=false

# Embeddings
GEMINI_API_KEY=
EMBEDDINGS_MODEL=gemini-embedding-001
EMBEDDING_DIM_FALLBACK=768

# Chunking
CHUNK_SIZE=512
CHUNK_OVERLAP=50

